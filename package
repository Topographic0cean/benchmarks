#!/bin/bash -l

source $HOME/.python3/bin/activate
source /etc/neverwinter.cfg

/bin/rm -rf benchmark_update.json
for file in data/*.txt; do
  echo " ==========  $file"
    python update_benchmarks.mongodb.py  $file >> benchmark_update.json
done

mongoimport -u $DATABASE_USER -p $MONGODB_PASSWORD -d $DATABASE_USER -c computers --drop --file=benchmark_update.json

